  "exampleQuestionDefinition": {
    "questionId": "governance_decision_authority",
    "riskAreaId": "governance",
    "text": "Who has ultimate decision-making authority for family financial and strategic matters?",
    "helpText": "Clear decision-making authority reduces conflicts and ensures timely decisions during crises.",
    "learnMore": "Establish a clear governance hierarchy with documented decision rights for different types of decisions and circumstances.",
    "riskRelevance": "Unclear authority creates decision paralysis during emergencies and can lead to family conflicts over important matters.",
    "type": "single-choice",
    "options": [
      {
        "value": "patriarch_matriarch",
        "label": "Patriarch/Matriarch has sole authority",
        "description": "One family leader makes all major decisions"
      },
      {
        "value": "family_council",
        "label": "Family council or board",
        "description": "Formal group with defined membership and voting procedures"
      },
      {
        "value": "consensus_required",
        "label": "All family members must agree",
        "description": "Unanimous consensus required for major decisions"
      },
      {
        "value": "unclear_undefined",
        "label": "It's not clearly defined",
        "description": "No formal structure or unclear who has authority"
      }
    ],
    "required": true,
    "weight": 3,
    "scoreMap": {
      "patriarch_matriarch": 2,
      "family_council": 3,
      "consensus_required": 1,
      "unclear_undefined": 0
    },
    "remediationAction": "Establish a clear family governance charter that defines decision-making authority, voting procedures, and escalation processes for different types of family decisions."
  }
