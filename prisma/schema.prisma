// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADVISOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String
  name          String?
  image         String?
  role          UserRole  @default(USER)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  mfaRecoveryCodes Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  assessments   Assessment[]
  householdMembers HouseholdMember[]
  intakeInterviews IntakeInterview[]
  advisorProfile AdvisorProfile?
  clientAssignments ClientAdvisorAssignment[] @relation("ClientAssignments")

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  mfaVerified  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  used       Boolean  @default(false)

  @@unique([identifier, token])
}

model Assessment {
  id            String           @id @default(cuid())
  userId        String
  version       Int              @default(1)
  status        AssessmentStatus @default(IN_PROGRESS)
  currentPillar String?
  currentQuestionIndex Int?      @default(0)
  startedAt     DateTime         @default(now())
  completedAt   DateTime?
  updatedAt     DateTime         @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses     AssessmentResponse[]
  scores        PillarScore[]

  @@index([userId])
  @@index([status])
}

model AssessmentResponse {
  id           String   @id @default(cuid())
  assessmentId String
  questionId   String
  pillar       String
  subCategory  String
  answer       Json
  skipped      Boolean  @default(false)
  answeredAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
}

model PillarScore {
  id           String    @id @default(cuid())
  assessmentId String
  pillar       String
  score        Float
  riskLevel    RiskLevel
  breakdown    Json
  missingControls Json?
  calculatedAt DateTime  @default(now())

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, pillar])
  @@index([assessmentId])
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FamilyRelationship {
  SPOUSE
  CHILD
  PARENT
  SIBLING
  GRANDCHILD
  GRANDPARENT
  OTHER
}

enum GovernanceRole {
  DECISION_MAKER
  ADVISOR
  SUCCESSOR
  BENEFICIARY
  TRUSTEE
  EXECUTOR
  OTHER
}

enum IntakeStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SUBMITTED
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model HouseholdMember {
  id             String             @id @default(cuid())
  userId         String
  fullName       String
  age            Int?
  occupation     String?
  phone          String?
  email          String?
  relationship   FamilyRelationship
  governanceRoles GovernanceRole[]
  isResident     Boolean            @default(true)
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model IntakeInterview {
  id                   String      @id @default(cuid())
  userId               String
  status               IntakeStatus @default(NOT_STARTED)
  currentQuestionIndex Int         @default(0)
  startedAt            DateTime?
  completedAt          DateTime?
  submittedAt          DateTime?
  updatedAt            DateTime    @updatedAt

  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses            IntakeResponse[]
  approval             IntakeApproval?

  @@index([userId])
  @@index([status])
}

model IntakeResponse {
  id                  String              @id @default(cuid())
  interviewId         String
  questionId          String
  audioUrl            String?
  audioDuration       Float?
  transcription       String?
  transcriptionStatus TranscriptionStatus @default(PENDING)
  answeredAt          DateTime?
  updatedAt           DateTime            @updatedAt

  interview           IntakeInterview     @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@unique([interviewId, questionId])
  @@index([interviewId])
}

enum AssignmentStatus {
  ACTIVE
  INACTIVE
}

enum ApprovalStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum NotificationType {
  NEW_INTAKE
  INTAKE_UPDATED
  SYSTEM
}

model AdvisorProfile {
  id               String                     @id @default(cuid())
  userId           String                     @unique
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  specializations  String[]
  licenseNumber    String?
  firmName         String?
  bio              String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  clientAssignments ClientAdvisorAssignment[] @relation("AdvisorAssignments")
  approvals        IntakeApproval[]
  notifications    AdvisorNotification[]

  @@index([userId])
}

model ClientAdvisorAssignment {
  id         String           @id @default(cuid())
  clientId   String
  advisorId  String
  assignedAt DateTime         @default(now())
  status     AssignmentStatus @default(ACTIVE)
  client     User             @relation("ClientAssignments", fields: [clientId], references: [id], onDelete: Cascade)
  advisor    AdvisorProfile   @relation("AdvisorAssignments", fields: [advisorId], references: [id], onDelete: Cascade)

  @@unique([clientId, advisorId])
  @@index([advisorId])
  @@index([clientId])
}

model IntakeApproval {
  id           String          @id @default(cuid())
  interviewId  String          @unique
  advisorId    String
  status       ApprovalStatus  @default(PENDING)
  focusAreas   String[]
  notes        String?
  reviewedAt   DateTime?
  approvedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  interview    IntakeInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  advisor      AdvisorProfile  @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([interviewId])
}

model AdvisorNotification {
  id          String           @id @default(cuid())
  advisorId   String
  type        NotificationType
  title       String
  message     String
  referenceId String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())
  advisor     AdvisorProfile   @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId, read])
}
