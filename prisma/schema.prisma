// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADVISOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String
  name          String?
  firstName     String?
  lastName      String?
  image         String?
  role          UserRole  @default(USER)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  mfaRecoveryCodes Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  assessments   Assessment[]
  householdMembers HouseholdMember[]
  intakeInterviews IntakeInterview[]
  advisorProfile AdvisorProfile?
  clientProfile  ClientProfile?
  clientAssignments ClientAdvisorAssignment[] @relation("ClientAssignments")
  documentRequirements DocumentRequirement[] @relation("ClientDocuments")
  notificationPreference NotificationPreference?
  subscription            Subscription?

  @@index([email])
}

enum SubscriptionTier {
  STARTER
  GROWTH
  PROFESSIONAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
  GRACE_PERIOD
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripePriceId        String?
  stripeSubscriptionId String?            @unique
  tier                 SubscriptionTier
  status               SubscriptionStatus
  clientLimit          Int
  billingCycle         BillingCycle
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs SubscriptionAuditLog[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model SubscriptionAuditLog {
  id               String            @id @default(cuid())
  subscriptionId   String
  action           String
  previousTier     SubscriptionTier?
  newTier          SubscriptionTier?
  metadata         Json?
  timestamp        DateTime          @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  mfaVerified  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  used       Boolean  @default(false)

  @@unique([identifier, token])
}

model Assessment {
  id            String           @id @default(cuid())
  userId        String
  version       Int              @default(1)
  status        AssessmentStatus @default(IN_PROGRESS)
  currentPillar String?
  currentQuestionIndex Int?      @default(0)
  startedAt     DateTime         @default(now())
  completedAt   DateTime?
  updatedAt     DateTime         @updatedAt
  approvalId    String?          // Links to IntakeApproval for customized assessments

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses     AssessmentResponse[]
  scores        PillarScore[]

  @@index([userId])
  @@index([status])
}

model AssessmentResponse {
  id           String   @id @default(cuid())
  assessmentId String
  questionId   String
  pillar       String
  subCategory  String
  answer       Json
  skipped      Boolean  @default(false)
  answeredAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
}

model PillarScore {
  id           String    @id @default(cuid())
  assessmentId String
  pillar       String
  score        Float
  riskLevel    RiskLevel
  breakdown    Json
  missingControls Json?
  calculatedAt DateTime  @default(now())

  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, pillar])
  @@index([assessmentId])
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InvitationStatus {
  SENT
  OPENED
  REGISTERED
  EXPIRED
}

enum ClientWorkflowStage {
  INVITED
  REGISTERED
  INTAKE_IN_PROGRESS
  INTAKE_COMPLETE
  ASSESSMENT_IN_PROGRESS
  ASSESSMENT_COMPLETE
  DOCUMENTS_REQUIRED
  COMPLETE
}

enum FamilyRelationship {
  SPOUSE
  CHILD
  PARENT
  SIBLING
  GRANDCHILD
  GRANDPARENT
  OTHER
}

enum GovernanceRole {
  DECISION_MAKER
  ADVISOR
  SUCCESSOR
  BENEFICIARY
  TRUSTEE
  EXECUTOR
  OTHER
}

enum IntakeStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SUBMITTED
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model HouseholdMember {
  id             String             @id @default(cuid())
  userId         String
  fullName       String
  age            Int?
  occupation     String?
  phone          String?
  email          String?
  relationship   FamilyRelationship
  governanceRoles GovernanceRole[]
  isResident     Boolean            @default(true)
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model IntakeInterview {
  id                   String      @id @default(cuid())
  userId               String
  status               IntakeStatus @default(NOT_STARTED)
  currentQuestionIndex Int         @default(0)
  startedAt            DateTime?
  completedAt          DateTime?
  submittedAt          DateTime?
  updatedAt            DateTime    @updatedAt

  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses            IntakeResponse[]
  approval             IntakeApproval?

  @@index([userId])
  @@index([status])
}

model IntakeResponse {
  id                  String              @id @default(cuid())
  interviewId         String
  questionId          String
  audioUrl            String?
  audioDuration       Float?
  transcription       String?
  transcriptionStatus TranscriptionStatus @default(PENDING)
  answeredAt          DateTime?
  updatedAt           DateTime            @updatedAt

  interview           IntakeInterview     @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@unique([interviewId, questionId])
  @@index([interviewId])
}

enum AssignmentStatus {
  ACTIVE
  INACTIVE
}

enum ApprovalStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum NotificationType {
  NEW_INTAKE
  INTAKE_UPDATED
  NEW_LEAD
  SYSTEM
  CLIENT_REGISTERED
  MILESTONE_COMPLETE
  WORKFLOW_STALLED
  DOCUMENT_UPLOADED
}

enum FamilyComplexity {
  SINGLE_HOUSEHOLD
  MULTI_GENERATIONAL
  FAMILY_BUSINESS_INVOLVED
}

model GovernanceReviewLead {
  id                    String            @id @default(cuid())
  name                  String
  email                 String
  familyOfficeName      String
  primaryAdvisor        String?
  familyComplexity      FamilyComplexity
  promptedInterest      String?
  createdAt             DateTime          @default(now())

  @@index([email])
  @@index([createdAt])
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  prefillEmail String?  // optional: prefill signup form when this code is used
  expiresAt  DateTime?
  maxUses     Int?
  usedCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  createdBy   String?
  status      InvitationStatus @default(SENT)
  statusUpdatedAt DateTime @default(now())
  personalMessage String?
  clientName  String?
  resendCount Int       @default(0)

  advisor     AdvisorProfile? @relation(fields: [createdBy], references: [id])

  @@index([code])
  @@index([createdBy])
  @@index([status])
}

model AdvisorProfile {
  id               String                     @id @default(cuid())
  userId           String                     @unique
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  specializations  String[]
  licenseNumber    String?
  firmName         String?
  bio              String?
  phone            String?
  jobTitle         String?
  logoUrl          String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  clientAssignments ClientAdvisorAssignment[] @relation("AdvisorAssignments")
  approvals        IntakeApproval[]
  notifications    AdvisorNotification[]
  invitations      InviteCode[]
  documentRequirements DocumentRequirement[]

  @@index([userId])
}

model ClientProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  dateOfBirth  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model ClientAdvisorAssignment {
  id         String           @id @default(cuid())
  clientId   String
  advisorId  String
  assignedAt DateTime         @default(now())
  status     AssignmentStatus @default(ACTIVE)
  client     User             @relation("ClientAssignments", fields: [clientId], references: [id], onDelete: Cascade)
  advisor    AdvisorProfile   @relation("AdvisorAssignments", fields: [advisorId], references: [id], onDelete: Cascade)

  @@unique([clientId, advisorId])
  @@index([advisorId])
  @@index([clientId])
}

model IntakeApproval {
  id           String          @id @default(cuid())
  interviewId  String          @unique
  advisorId    String
  status       ApprovalStatus  @default(PENDING)
  focusAreas   String[]
  notes        String?
  reviewedAt   DateTime?
  approvedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  interview    IntakeInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  advisor      AdvisorProfile  @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([interviewId])
}

model AdvisorNotification {
  id          String           @id @default(cuid())
  advisorId   String
  type        NotificationType
  title       String
  message     String
  referenceId String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())
  advisor     AdvisorProfile   @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId, read])
}

model DocumentRequirement {
  id           String   @id @default(cuid())
  advisorId    String   // AdvisorProfile.id
  clientId     String   // User.id (client)
  name         String   // e.g., "Trust Agreement", "Tax Return"
  description  String?  // Additional details about what's needed
  required     Boolean  @default(true)
  fulfilled    Boolean  @default(false)
  fulfilledAt  DateTime?
  fileKey      String?  // S3 object key
  fileName     String?  // Original file name for display
  fileSize     Int?     // File size in bytes
  fileMimeType String?  // Validated MIME type
  lastReminderSentAt DateTime? // Track when last reminder was sent to prevent spam
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  advisor      AdvisorProfile @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  client       User           @relation("ClientDocuments", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([clientId])
  @@index([advisorId, clientId])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email notification toggles
  emailEnabled          Boolean @default(true)
  emailMilestones       Boolean @default(true)   // NOTIFY-03: milestone completions
  emailReminders        Boolean @default(true)    // NOTIFY-02: assessment reminders
  emailStalled          Boolean @default(true)    // NOTIFY-04: stalled workflow alerts
  emailRegistrations    Boolean @default(true)    // NOTIFY-01: client registrations

  // Frequency control
  reminderFrequencyDays Int     @default(7)       // Min days between reminder emails

  // Quiet hours (optional, store as "HH:MM" strings, UTC)
  quietStart   String?  // e.g., "22:00"
  quietEnd     String?  // e.g., "08:00"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
}
